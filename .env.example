# ── Authentication ──────────────────────────────────────────────────────────────
CIVIC_CLIENT_ID=                        # required

# ── Database ─────────────────────────────────────────────────────────────────────
DATABASE_URL=                           # required (e.g. postgresql+asyncpg://user:pass@host/db)
DATABASE_POOL_SIZE=5

# ── Refresh Scheduler ────────────────────────────────────────────────────────────
REFRESH_INTERVAL_MINUTES=30
REFRESH_CYCLE_TIMEOUT_MINUTES=25

# ── LLM / OpenRouter ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=                     # required
LLM_MODEL=mistralai/mistral-7b-instruct
LLM_CONCURRENCY=1
LLM_MAX_ITERATIONS=6
LLM_TEMPERATURE=0.2
LLM_REACT_PROMPT_FILE=                  # optional — path to custom ReAct prompt file
LLM_DELTA_THRESHOLD=5.0
LLM_MAX_TICKERS_PER_CYCLE=50
LLM_MAX_CONTEXT_CHARS=2000

# ── Data Fetching ─────────────────────────────────────────────────────────────────
FETCH_CONCURRENCY=20
NEWS_API_KEY=                           # optional
FINNHUB_API_KEY=                        # optional

# ── Scoring Thresholds ────────────────────────────────────────────────────────────
SCORE_BUY_THRESHOLD=35
SCORE_SELL_THRESHOLD=65

# ── Tools ─────────────────────────────────────────────────────────────────────────
TOOLS_CONFIG_PATH=tools_config.yaml

# ── Rate Limiting ─────────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute

# ── History Retention ─────────────────────────────────────────────────────────────
SCORE_HISTORY_RETENTION_DAYS=90
